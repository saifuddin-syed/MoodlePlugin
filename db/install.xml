<?xml version="1.0" encoding="UTF-8" ?>
<XMLDB PATH="local/automation/db" VERSION="2026022100" COMMENT="Student AI tables"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:noNamespaceSchemaLocation="../../../lib/xmldb/xmldb.xsd">

    <TABLES>

        <!-- Student Chat History -->
        <TABLE NAME="local_automation_student_chat" COMMENT="Stores student chatbot conversations">
            <FIELDS>
                <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
                <FIELD NAME="studentid" TYPE="int" LENGTH="10" NOTNULL="true"/>
                <FIELD NAME="courseid" TYPE="int" LENGTH="10" NOTNULL="true"/>
                <FIELD NAME="message" TYPE="text" NOTNULL="true"/>
                <FIELD NAME="sender" TYPE="char" LENGTH="10" NOTNULL="true"/>
                <FIELD NAME="timecreated" TYPE="int" LENGTH="10" NOTNULL="true"/>
            </FIELDS>
            <KEYS>
                <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
            </KEYS>
        </TABLE>

        <!-- Student Quiz -->
        <TABLE NAME="local_automation_student_quiz">
            <FIELDS>
                <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
                <FIELD NAME="studentid" TYPE="int" LENGTH="10" NOTNULL="true"/>
                <FIELD NAME="courseid" TYPE="int" LENGTH="10" NOTNULL="true"/>
                <FIELD NAME="topic" TYPE="char" LENGTH="255" NOTNULL="true"/>
                <FIELD NAME="score" TYPE="int" LENGTH="5" NOTNULL="true"/>
                <FIELD NAME="total" TYPE="int" LENGTH="5" NOTNULL="true"/>
                <FIELD NAME="difficulty" TYPE="char" LENGTH="20" NOTNULL="true"/>
                <FIELD NAME="recommendation" TYPE="text"/>
                <FIELD NAME="timecreated" TYPE="int" LENGTH="10" NOTNULL="true"/>
            </FIELDS>
            <KEYS>
                <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
            </KEYS>
        </TABLE>


        <!-- Advice -->
        <TABLE NAME="local_automation_advice">
            <FIELDS>
                <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
                <FIELD NAME="studentid" TYPE="int" LENGTH="10" NOTNULL="true"/>
                <FIELD NAME="teacherid" TYPE="int" LENGTH="10" NOTNULL="true"/>
                <FIELD NAME="courseid" TYPE="int" LENGTH="10" NOTNULL="true"/>
                <FIELD NAME="advice" TYPE="text" NOTNULL="true"/>
                <FIELD NAME="timecreated" TYPE="int" LENGTH="10" NOTNULL="true"/>
            </FIELDS>
            <KEYS>
                <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
            </KEYS>
        </TABLE>

        <TABLE NAME="local_automation_quiz_lock" COMMENT="Stores difficulty lock per student">
            <FIELDS>
                <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
                <FIELD NAME="studentid" TYPE="int" LENGTH="10" NOTNULL="true"/>
                <FIELD NAME="courseid" TYPE="int" LENGTH="10" NOTNULL="true"/>
                <FIELD NAME="difficulty" TYPE="char" LENGTH="10" NOTNULL="true"/>
                <FIELD NAME="locked" TYPE="int" LENGTH="1" NOTNULL="true" DEFAULT="0"/>
                <FIELD NAME="timecreated" TYPE="int" LENGTH="10" NOTNULL="true"/>
                <FIELD NAME="timemodified" TYPE="int" LENGTH="10" NOTNULL="true"/>
            </FIELDS>

            <KEYS>
                <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
            </KEYS>

            <INDEXES>
                <INDEX NAME="uniq_lock" UNIQUE="true" FIELDS="studentid, courseid, difficulty"/>
            </INDEXES>
        </TABLE>

        <TABLE NAME="local_automation_quiz_questions" COMMENT="Stores question-level data">
            <FIELDS>
                <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>

                <!-- Link to quiz attempt -->
                <FIELD NAME="quizattemptid" TYPE="int" LENGTH="10" NOTNULL="true"/>

                <!-- Student & course -->
                <FIELD NAME="studentid" TYPE="int" LENGTH="10" NOTNULL="true"/>
                <FIELD NAME="courseid" TYPE="int" LENGTH="10" NOTNULL="true"/>

                <!-- Question info -->
                <FIELD NAME="questionid" TYPE="int" LENGTH="10" NOTNULL="true"/>
                <FIELD NAME="questiontext" TYPE="text" NOTNULL="true"/>
                <FIELD NAME="topic" TYPE="char" LENGTH="255" NOTNULL="true"/>
                <FIELD NAME="unit" TYPE="char" LENGTH="255" NOTNULL="true"/>

                <!-- Performance -->
                <FIELD NAME="score" TYPE="int" LENGTH="5" NOTNULL="true"/>
                <FIELD NAME="maxscore" TYPE="int" LENGTH="5" NOTNULL="true"/>

                <FIELD NAME="timecreated" TYPE="int" LENGTH="10" NOTNULL="true"/>
            </FIELDS>

            <KEYS>
                <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
            </KEYS>

            <INDEXES>
                <INDEX NAME="quiz_idx" UNIQUE="false" FIELDS="quizattemptid"/>
                <INDEX NAME="student_idx" UNIQUE="false" FIELDS="studentid"/>
                <INDEX NAME="unit_idx" UNIQUE="false" FIELDS="unit"/>
            </INDEXES>
        </TABLE>

    </TABLES>
</XMLDB>