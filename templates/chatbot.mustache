<div id="ai-chatbot-button" class="ai-chatbot-btn">
    ✨
</div>

<div id="ai-chatbot-modal" class="ai-chatbot-modal hidden">
    <div class="chat-header">
        <span>AI Assistant</span>
        <button id="chatbot-close-btn">×</button>
    </div>

    <!-- Tabs -->
    <div class="chat-tabs">
        <button class="chat-tab active" data-mode="assistant">AI Assistant</button>
        <button class="chat-tab" data-mode="qb">QB Generator</button>
        <button class="chat-tab" data-mode="quiz">Quiz Generator</button>
        <a id="analytics-btn"
href="{{config.wwwroot}}/local/automation/analytics_page.php?courseid={{courseid}}"
target="_blank"
style="
position:fixed;
bottom:100px;
right:20px;
background:#4f46e5;
color:white;
padding:12px 16px;
border-radius:20px;
text-decoration:none;
font-weight:600;
z-index:9999;
">
📊 Analytics
</a>        
    </div>

    <div id="chatbot-messages" class="chat-messages"></div>
    <div id="chatbot-action-area"></div>

    <div class="chat-input-area">
        <textarea id="chatbot-input"
                  rows="1"
                  placeholder="Type a message... autocomplete="off""></textarea>
        <button id="chatbot-send-btn">Send</button>
    </div>

</div>
